	<parameter name="P_ENTDCDGO" class="java.lang.Long">
		<description><![CDATA[codigo del prestamo]]></description>
	</parameter>
	<parameter name="P_TPAPCDGO" class="java.lang.Long"/>
	<parameter name="P_IMAGEN" class="java.awt.Image"/>
	<parameter name="P_USUARIO" class="java.lang.String"/>
	<query language="SQL"><![CDATA[SELECT   *
FROM	 crd.APRT a, crd.TPAP t, crd.ENTD e 
WHERE	 a.TPAPCDGO  = t.TPAPCDGO 
		 AND   a.ENTDCDGO = e.ENTDCDGO 
		 AND   a.ENTDCDGO = $P{P_ENTDCDGO}
	     AND   a.TPAPCDGO =  $P{P_TPAPCDGO}
	     ORDER BY a.APRTFCTR ASC]]></query>
