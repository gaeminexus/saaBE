<!-- Created with Jaspersoft Studio version 7.0.3.final using JasperReports Library version 7.0.3-41034ca841d452f3305ba55b9042260aaa1ab5dd  -->
<jasperReport name="RPRT_TBLA_ACML" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="e755f84b-cdb8-4a99-a846-a56911786218">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Oracle"/>
	<parameter name="P_PRSTCDGO" class="java.lang.Integer">
		<description><![CDATA[codigo del prestamo]]></description>
	</parameter>
	<parameter name="P_IMAGEN" class="java.awt.Image"/>
	<parameter name="P_USUARIO" class="java.lang.String"/>
	<query language="SQL"><![CDATA[SELECT
    TRIM(E.ENTDNMID)        AS IDENTIFICACION,
    TRIM(E.ENTDRZNS)        AS NOMBRES,
    P.PRSTIDAS              AS NUMERO_PRESTAMO,
    P.PRSTMNSL              AS MONTO_CREDITO,
    P.PRSTMNLD              AS LIQUIDO_RECIBIR,
    P.PRSTPLZO              AS PLAZO_MESES,
    P.PRSTTSAA              AS TASA_INTERES,
    P.PRSTAMRT              AS TIPO_AMORTIZACION,
    P.PRSTUSRG              AS CREADO_POR,
    TRUNC(P.PRSTFCHA)       AS FECHA_CONCESION,
    TRUNC(P.PRSTFCIN)       AS FECHA_PRIMER_DIVIDENDO,
    TRUNC(P.PRSTFCFN)       AS FECHA_ULTIMO_DIVIDENDO,
    P.PRSTUSMD              AS USUARIO,
    P.PRSTVLCT              AS VALOR_CUOTA,
    P.PRSTSLTT              AS SALDO_TOTAL,
    DECODE(P.PRSTIDST , 1, 'GENERADO',
           2, 'VIGENTE',
           3, 'CANCELADO',
           4, 'CANCELADO ANTICIPADO',
           5, 'CANCELADO POR NOVACION',
           6, 'PENDIENTE APROBACION',
           7, 'RECHAZADO',
           8, 'DE PLAZO VENCIDO',
           9, 'CANCELADO POR REVISAR',
           10, 'VIGENTE POR REVISAR',
           11, 'EN MORA')              AS ESTADO_PRESTAMO,
    U.DTPRNMCT              AS NUMERO_CUOTA,
    TRUNC(U.DTPRFCVN)       AS FECHA_VENCIMIENTO,
    U.DTPRSLOT              AS PAGO_EXTRA,
    U.DTPRSLCP               AS SALDO_INICIAL,
    U.DTPRCPTL              AS CAPITAL,
    U.DTPRINTR              AS INTERES,
    U.DTPRDSGR              AS SEGURO_DESGRAVA,
    U.DTPRTTLL              AS CUOTA_TOTAL,
    DECODE(U.DTPRESTD, 1, 'PENDIENTE',
           2, 'ACTIVA',
           3, 'EMITIDA',
           4, 'PAGADA',
           5, 'EN MORA',
           6, 'PARCIAL',
           7, 'CANCELADA ANTICIPADA',
           8, 'VENCIDA')              AS ESTADO_DIVIDENDOS
FROM CRD.PRST P,
     CRD.ENTD E,
     CRD.DTPR U
WHERE P.PRSTCDGO =  $P{P_PRSTCDGO} 
  AND E.ENTDCDGO = P.ENTDCDGO
  AND U.PRSTCDGO = P.PRSTCDGO
  AND U.DTPRESTD != 7
ORDER BY U.DTPRNMCT;]]></query>
