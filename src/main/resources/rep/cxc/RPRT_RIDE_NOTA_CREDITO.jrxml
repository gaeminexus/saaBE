<!-- Created with Jaspersoft Studio version 7.0.3.final using JasperReports Library version 7.0.3-41034ca841d452f3305ba55b9042260aaa1ab5dd  -->
<jasperReport name="RPRT_RIDE_NOTA_CREDITO" language="java" pageWidth="595" pageHeight="842" columnWidth="535" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20" uuid="e2b3c4d5-f6a7-8901-bcde-234567890abc">
	<parameter name="P_ID_NOTA_CREDITO" class="java.lang.Long">
		<defaultValueExpression><![CDATA[0L]]></defaultValueExpression>
	</parameter>
	<query language="SQL"><![CDATA[
		SELECT
		    /* ── Cabecera de la nota de crédito ──────────────────── */
		    nc.CLAVE                                                            AS clave,
		    nc.NUMERO                                                           AS numeroNC,
		    COALESCE(nc.AUTORIZACION, nc.CLAVE)                                AS numeroAutorizacion,
		    TO_CHAR(nc.FECHA,              'DD/MM/YYYY')                        AS fechaEmision,
		    TO_CHAR(nc.FECHAAUTORIZACION,  'DD/MM/YYYY HH24:MI:SS')             AS fechaAutorizacion,
		    CASE WHEN nc.AMBIENTE = 2 THEN 'PRODUCCIÓN' ELSE 'PRUEBAS' END     AS ambiente,
		    /* ── Documento modificado ──────────────────────────────── */
		    COALESCE(nc.TIPODOCMODIFICADO, '')                                  AS tipoDocModificado,
		    COALESCE(nc.NUMDOCMODIFICADO,  '')                                  AS numDocModificado,
		    TO_CHAR(nc.FECHAEMISIONDM,     'DD/MM/YYYY')                        AS fechaEmisionDocMod,
		    /* ── Subtotales e impuestos ─────────────────────────────── */
		    COALESCE(nc.SUBTOTAL,  0)                                           AS subtotalIva,
		    COALESCE(nc.SUBCERO,   0)                                           AS subtotal0,
		    0                                                                   AS subtotal5,
		    0                                                                   AS subtotal8,
		    COALESCE(nc.DESCUENTO, 0)                                           AS descuentoTotal,
		    COALESCE(nc.VIVA,      0)                                           AS iva,
		    0                                                                   AS iva5,
		    0                                                                   AS iva8,
		    TO_CHAR(TRUNC(COALESCE(nc.PIVA, 15)))                               AS porcIva,
		    COALESCE(nc.TOTAL,     0)                                           AS valorModificacion,
		    COALESCE(nc.OBSERVACION, '')                                        AS observacion,
		    /* ── Facturador ──────────────────────────────────────────── */
		    COALESCE(fd.NUMDOC,                '')                              AS rucFacturador,
		    COALESCE(fd.RAZONSOCIAL,           '')                              AS razonSocial,
		    COALESCE(fd.NOMBRECOMERCIAL,       '')                              AS nombreComercial,
		    COALESCE(fd.DIRECCION,             '')                              AS direccionFcdr,
		    COALESCE(fd.TELEFONO,              '')                              AS telefonoFcdr,
		    COALESCE(fd.MAIL,                  '')                              AS emailFcdr,
		    CASE WHEN fd.CONTABILIDAD    = 1 THEN 'SI' ELSE 'NO' END           AS obligadoContabilidad,
		    COALESCE(fd.AGENTERETENCION,       '')                              AS agenteRetencion,
		    COALESCE(fd.CONTRIBUYENTEESPECIAL, '')                              AS contribuyenteEspecial,
		    CASE
		        WHEN fd.RIMPE        = 1 THEN 'CONTRIBUYENTE RÉGIMEN RIMPE'
		        WHEN fd.POPULARRIMPE = 1 THEN 'CONTRIBUYENTE NEGOCIO POPULAR - RÉGIMEN RIMPE'
		        WHEN fd.MICROEMPRESA = 1 THEN 'CONTRIBUYENTE RÉGIMEN MICROEMPRESAS'
		        ELSE ''
		    END                                                                 AS tipoEmpresa,
		    COALESCE(fd.LOGO, '')                                               AS pathLogo,
		    /* ── Comprador / Titular ──────────────────────────────────── */
		    COALESCE(t.TTLRNMBR, '')                                            AS razonSocialComprador,
		    COALESCE(t.TTLRIDNT, '')                                            AS identificacionComprador,
		    COALESCE(t.TTLRDRCC, '')                                            AS direccionComprador,
		    COALESCE(t.TTLRMLLL, '')                                            AS emailComprador,
		    /* ── Línea de detalle ──────────────────────────────────────── */
		    COALESCE(
		        (SELECT p2.CODIGO FROM CBR.PRDC p2 WHERE p2.ID = d.PRODUCTO),
		        '')                                                             AS codigo,
		    COALESCE(d.DESCRIPCION,   '')                                       AS descripcion,
		    COALESCE(d.CANTIDAD,      0)                                        AS cantidad,
		    COALESCE(d.VALOR,         0)                                        AS valor,
		    COALESCE(d.SUBTOTAL, COALESCE(d.CANTIDAD,0)*COALESCE(d.VALOR,0))   AS subTotal,
		    COALESCE(d.DESCUENTO,     0)                                        AS descuento,
		    COALESCE(d.BASEIMPONIBLE, 0)                                        AS baseImponible
		FROM      CBR.NTCR nc
		JOIN      CBR.FCDR fd ON fd.ID       = nc.FACTURADOR
		LEFT JOIN TSR.TTLR  t ON t.TTLRCDGO  = nc.TITULAR
		LEFT JOIN CBR.DTNC  d ON d.NOTACREDITO = nc.ID
		WHERE nc.ID = $P{P_ID_NOTA_CREDITO}
		ORDER BY d.ID
	]]></query>
