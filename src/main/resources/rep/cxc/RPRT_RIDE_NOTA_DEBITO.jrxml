<!-- Created with Jaspersoft Studio version 7.0.3.final using JasperReports Library version 7.0.3-41034ca841d452f3305ba55b9042260aaa1ab5dd  -->
<jasperReport name="RPRT_RIDE_NOTA_DEBITO" language="java" pageWidth="595" pageHeight="842" columnWidth="535" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20" uuid="a3c4d5e6-f7a8-9012-bcde-345678901234">
	<parameter name="P_ID_NOTA_DEBITO" class="java.lang.Long">
		<defaultValueExpression><![CDATA[0L]]></defaultValueExpression>
	</parameter>
	<query language="SQL"><![CDATA[
		SELECT
		    /* ── Cabecera de la nota de débito ───────────────────── */
		    nd.CLAVE                                                            AS clave,
		    nd.NUMERO                                                           AS numeroND,
		    COALESCE(nd.AUTORIZACION, nd.CLAVE)                                AS numeroAutorizacion,
		    TO_CHAR(nd.FECHA,              'DD/MM/YYYY')                        AS fechaEmision,
		    TO_CHAR(nd.FECHAAUTORIZACION,  'DD/MM/YYYY HH24:MI:SS')             AS fechaAutorizacion,
		    CASE WHEN nd.AMBIENTE = 2 THEN 'PRODUCCIÓN' ELSE 'PRUEBAS' END     AS ambiente,
		    /* ── Documento modificado ──────────────────────────────── */
		    CASE WHEN COALESCE(nd.TIPODOCMODIFICADO, '01') = '01' THEN 'FACTURA' ELSE 'N/D' END  AS tipoDocModificado,
		    COALESCE(nd.NUMDOCMODIFICADO,  '')                                  AS numDocModificado,
		    TO_CHAR(nd.FECHAEMISIONDM,     'DD/MM/YYYY')                        AS fechaEmisionDocMod,
		    /* ── Subtotales e impuestos ─────────────────────────────── */
		    COALESCE(nd.SUBTOTAL,  0)                                           AS subtotalIva,
		    COALESCE(nd.SUBCERO,   0)                                           AS subtotal0,
		    COALESCE(nd.DESCUENTO, 0)                                           AS descuentoTotal,
		    COALESCE(nd.VIVA,      0)                                           AS iva,
		    TO_CHAR(TRUNC(COALESCE(nd.PIVA, 15)))                               AS porcIva,
		    COALESCE(nd.TOTAL,     0)                                           AS valorTotal,
		    COALESCE(nd.OBSERVACION, '')                                        AS observacion,
		    /* ── Facturador ──────────────────────────────────────────── */
		    COALESCE(fd.NUMDOC,                '')                              AS rucFacturador,
		    COALESCE(fd.RAZONSOCIAL,           '')                              AS razonSocial,
		    COALESCE(fd.NOMBRECOMERCIAL,       '')                              AS nombreComercial,
		    COALESCE(fd.DIRECCION,             '')                              AS direccionFcdr,
		    COALESCE(fd.TELEFONO,              '')                              AS telefonoFcdr,
		    COALESCE(fd.MAIL,                  '')                              AS emailFcdr,
		    CASE WHEN fd.CONTABILIDAD    = 1 THEN 'SI' ELSE 'NO' END           AS obligadoContabilidad,
		    COALESCE(fd.AGENTERETENCION,       '')                              AS agenteRetencion,
		    COALESCE(fd.CONTRIBUYENTEESPECIAL, '')                              AS contribuyenteEspecial,
		    CASE
		        WHEN fd.RIMPE        = 1 THEN 'CONTRIBUYENTE RÉGIMEN RIMPE'
		        WHEN fd.POPULARRIMPE = 1 THEN 'CONTRIBUYENTE NEGOCIO POPULAR - RÉGIMEN RIMPE'
		        WHEN fd.MICROEMPRESA = 1 THEN 'CONTRIBUYENTE RÉGIMEN MICROEMPRESAS'
		        ELSE ''
		    END                                                                 AS tipoEmpresa,
		    COALESCE(fd.LOGO, '')                                               AS pathLogo,
		    /* ── Comprador / Titular ──────────────────────────────────── */
		    COALESCE(t.TTLRNMBR, '')                                            AS razonSocialComprador,
		    COALESCE(t.TTLRIDNT, '')                                            AS identificacionComprador,
		    COALESCE(t.TTLRDRCC, '')                                            AS direccionComprador,
		    COALESCE(t.TTLRMLLL, '')                                            AS emailComprador,
		    /* ── Motivos (línea de detalle de ND según SRI) ────────── */
		    COALESCE(d.DESCRIPCION, '')                                         AS razon,
		    COALESCE(d.VALOR,       0)                                          AS valorMotivo
		FROM      CBR.NTDB nd
		JOIN      CBR.FCDR fd ON fd.ID       = nd.FACTURADOR
		LEFT JOIN TSR.TTLR  t ON t.TTLRCDGO  = nd.TITULAR
		LEFT JOIN CBR.DTND  d ON d.NOTADEBITO = nd.ID
		WHERE nd.ID = $P{P_ID_NOTA_DEBITO}
		ORDER BY d.ID
	]]></query>
