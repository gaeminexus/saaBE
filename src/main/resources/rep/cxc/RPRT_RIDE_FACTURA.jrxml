		<band height="12" splitType="Stretch">
			<element kind="textField" uuid="cc000001-cccc-cccc-cccc-cccccccccccc" x="0" y="0" width="37" height="12" fontSize="7.0" textAdjust="StretchHeight" pattern="#,##0.00" hTextAlign="Center">
