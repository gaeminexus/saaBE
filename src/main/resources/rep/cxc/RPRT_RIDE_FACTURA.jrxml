<!-- Created with Jaspersoft Studio version 7.0.3.final using JasperReports Library version 7.0.3-41034ca841d452f3305ba55b9042260aaa1ab5dd  -->
<jasperReport name="RPRT_RIDE_FACTURA" language="java" pageWidth="595" pageHeight="842" columnWidth="535" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20" uuid="f1a2b3c4-d5e6-7890-abcd-1234567890ab">
	<parameter name="P_ID_FACTURA" class="java.lang.Long">
		<defaultValueExpression><![CDATA[0L]]></defaultValueExpression>
	</parameter>
	<query language="SQL"><![CDATA[
		SELECT
		    /* ── Cabecera de la factura ──────────────────────────── */
		    f.CLAVE                                                         AS clave,
		    f.NUMERO                                                        AS numeroFactura,
		    COALESCE(f.AUTORIZACION, f.CLAVE)                              AS numeroAutorizacion,
		    TO_CHAR(f.FECHA,             'DD/MM/YYYY')                     AS fechaEmision,
		    TO_CHAR(f.FECHAAUTORIZACION, 'DD/MM/YYYY HH24:MI:SS')          AS fechaAutorizacion,
		    CASE WHEN f.AMBIENTE = 2 THEN 'PRODUCCIÓN' ELSE 'PRUEBAS' END  AS ambiente,
		    /* ── Subtotales e impuestos ──────────────────────────── */
		    COALESCE(f.SUBTOTAL,  0)                                       AS subtotalIva,
		    COALESCE(f.SUBCERO,   0)                                       AS subtotal0,
		    COALESCE(f.SUBTOTAL5, 0)                                       AS subtotal5,
		    COALESCE(f.SUBTOTAL8, 0)                                       AS subtotal8,
		    0                                                              AS subtotalSinImp,
		    COALESCE(f.DESCUENTO, 0)                                       AS descuentoTotal,
		    COALESCE(f.VIVA,      0)                                       AS iva,
		    0                                                              AS iva5,
		    0                                                              AS iva8,
		    0                                                              AS propina,
		    TO_CHAR(TRUNC(COALESCE(f.PIVA, 15)))                           AS porcIva,
		    COALESCE(f.TOTAL,     0)                                       AS total,
		    COALESCE(f.OBSERVACION,            '')                         AS observacion,
		    COALESCE(fd.NUMDOC,                '')                         AS rucFacturador,
		    COALESCE(fd.RAZONSOCIAL,           '')                         AS razonSocial,
		    COALESCE(fd.NOMBRECOMERCIAL,       '')                         AS nombreComercial,
		    COALESCE(fd.DIRECCION,             '')                         AS direccionFcdr,
		    COALESCE(fd.TELEFONO,              '')                         AS telefonoFcdr,
		    COALESCE(fd.MAIL,                  '')                         AS emailFcdr,
		    CASE WHEN fd.CONTABILIDAD    = 1 THEN 'SI' ELSE 'NO' END      AS obligadoContabilidad,
		    COALESCE(fd.AGENTERETENCION,       '')                         AS agenteRetencion,
		    COALESCE(fd.CONTRIBUYENTEESPECIAL, '')                         AS contribuyenteEspecial,
		    CASE
		        WHEN fd.RIMPE        = 1 THEN 'CONTRIBUYENTE RÉGIMEN RIMPE'
		        WHEN fd.POPULARRIMPE = 1 THEN 'CONTRIBUYENTE NEGOCIO POPULAR - RÉGIMEN RIMPE'
		        WHEN fd.MICROEMPRESA = 1 THEN 'CONTRIBUYENTE RÉGIMEN MICROEMPRESAS'
		        ELSE ''
		    END                                                            AS tipoEmpresa,
		    COALESCE(fd.LOGO,                  '')                         AS pathLogo,
		    /* ── Comprador / Titular ─────────────────────────────── */
		    COALESCE(t.TTLRNMBR, '')                                       AS razonSocialComprador,
		    COALESCE(t.TTLRIDNT, '')                                       AS identificacionComprador,
		    COALESCE(t.TTLRDRCC, '')                                       AS direccionComprador,
		    COALESCE(t.TTLRMLLL, '')                                       AS emailComprador,
		    /* ── Formas de pago (subquery escalar) ─────────────── */
		    (SELECT COALESCE(
		                LISTAGG(
		                    COALESCE(
		                        (SELECT ts.DETALLE FROM CBR.TSRI ts WHERE ts.CODIGO = fp2.FORMAPAGO AND ROWNUM = 1),
		                        fp2.FORMAPAGO
		                    ) || ': $' || TO_CHAR(fp2.VALOR,'FM999,999,990.00'),
		                    CHR(10))
		                    WITHIN GROUP (ORDER BY fp2.ID)
		            , '')
		     FROM CBR.FPFC fp2
		     WHERE fp2.FACTURA = f.ID)                                     AS formasPago,
		    /* ── Línea de detalle ─────────────────────────────────── */
		    COALESCE(p.CODIGO,        '')                                  AS codigo,
		    COALESCE(p.CODIGOAUX,     '')                                  AS codigoAux,
		    COALESCE(d.DESCRIPCION,   '')                                  AS descripcion,
		    COALESCE(d.CANTIDAD,      0)                                   AS cantidad,
		    COALESCE(d.VALOR,         0)                                   AS valor,
		    COALESCE(d.SUBTOTAL, COALESCE(d.CANTIDAD,0)*COALESCE(d.VALOR,0)) AS subTotal,
		    COALESCE(d.DESCUENTO,     0)                                   AS descuento,
		    COALESCE(d.BASEIMPONIBLE, 0)                                   AS baseImponible
		FROM      CBR.FCTR f
		JOIN      CBR.FCDR fd ON fd.ID       = f.FACTURADOR
		LEFT JOIN TSR.TTLR  t ON t.TTLRCDGO  = f.COMPRADOR
		LEFT JOIN CBR.DTFC  d ON d.FACTURA   = f.ID
		LEFT JOIN CBR.PRDC  p ON p.ID        = d.PRODUCTO
		WHERE f.ID = $P{P_ID_FACTURA}
		ORDER BY d.ID
	]]></query>
