			<element kind="textField" uuid="cc000002-cccc-cccc-cccc-cccccccccccc" x="37" y="0" width="48" height="12" fontSize="7.0" textAdjust="StretchHeight" blankWhenNull="true" hTextAlign="Center">
				<expression><![CDATA[$F{codigo}]]></expression>
				<box>
