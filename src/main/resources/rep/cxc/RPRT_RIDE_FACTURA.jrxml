	<query language="SQL"><![CDATA[SELECT
        COALESCE(b.CODIGO, '')       AS codigo,
        COALESCE(b.CODIGOAUX, '')    AS codigoAux,
        a.DESCRIPCION                AS descripcion,
        COALESCE(a.CANTIDAD, 0)      AS cantidad,
        COALESCE(a.VALOR, 0)         AS valor,
        COALESCE(a.SUBTOTAL,
          COALESCE(a.CANTIDAD,0) * COALESCE(a.VALOR,0)) AS subTotal,
        COALESCE(a.DESCUENTO, 0)     AS descuento,
        COALESCE(a.BASEIMPONIBLE, 0) AS baseImponible
      FROM CBR.DTFC a
      LEFT JOIN CBR.PRDC b ON a.PRODUCTO = b.ID
      WHERE a.FACTURA = (
          SELECT ID FROM CBR.FCTR WHERE CLAVE = $P{P_CLAVE} FETCH FIRST 1 ROWS ONLY
      )
      ORDER BY a.ID]]></query>
